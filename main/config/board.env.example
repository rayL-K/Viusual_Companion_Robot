# ELF2 systemd 服务环境变量模板。复制为 board.env 后填写真实密钥；board.env 已被 Git 忽略。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
VISUAL_COMPANION_LLM_BACKEND=cloud
LIVE2D_CONTROL_HOST=0.0.0.0
LIVE2D_CONTROL_PORT=8765
VISUAL_COMPANION_PUBLIC_HOST=anima.veyralux.org
VISUAL_COMPANION_EMOTION_URL=http://127.0.0.1:8766
VISUAL_COMPANION_EMOTION_HOST=127.0.0.1
VISUAL_COMPANION_EMOTION_PORT=8766
# 公网部署必须设置高熵令牌；小程序首次使用时在“设备连接”中保存。
VISUAL_COMPANION_DEVICE_TOKEN=
