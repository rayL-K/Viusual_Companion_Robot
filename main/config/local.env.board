# Firefly RK3588 板端私有配置
# 复制为 local.env 后填入实际值

# ── 硅基流动 API ──
SILICONFLOW_KEY=sk-your-key-here

# ── VoxCPM2 本地 TTS ──
# 模型路径（绝对路径或相对于项目根）
VOXCPM_MODEL_PATH=main/models/voxcpm/VoxCPM2
VOXCPM_DEVICE=cpu

# ── sherpa-onnx ASR 模型 ──
# 模型目录，首次运行自动下载
SHERPA_ONNX_MODEL_ROOT=main/models/asr

# ── Live2D 前端 ──
# Vite 开发服务器端口（仅开发模式）
LIVE2D_STAGE_PORT=5173
# 控制服务端口
LIVE2D_CONTROL_PORT=8765

# ── 显示 ──
DISPLAY=:0
