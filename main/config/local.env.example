# 复制本文件为 main/config/local.env，并按本机实际路径修改。
# local.env 不进入 Git，用于保存本机私有模型路径和可选外部服务密钥。

# 可选：未配置时本地 TTS/ASR/视觉仍可运行，但在线 LLM 对话不可用。
# DEEPSEEK_API_KEY=
# SILICONFLOW_KEY=

# VoxCPM2 模型权重目录。目录内应包含 model.safetensors、audiovae.pth、config.json 等文件。
VOXCPM_MODEL_PATH=E:\path\to\VoxCPM2

# 默认 auto。Windows 本机通常使用 auto/cpu；Firefly 上按实际推理环境调整。
# VOXCPM_DEVICE=auto

# 可选：SenseVoice 模型目录；留空时使用 main/models/asr，并在首次识别时自动下载。
# SHERPA_ONNX_MODEL_ROOT=main/models/asr
