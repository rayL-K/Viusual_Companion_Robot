{
  "version": 1,
  "defaultDurationMs": 180,
  "description": "Live2D 嘴型可视化测试配置。每个 sounds 条目都可以单独调整嘴型参数和临时合成声音参数。",
  "parameterGuide": {
    "open": "嘴巴纵向张开程度，0 表示几乎闭合，1 表示最大开口。",
    "width": "嘴巴横向展开程度，0 表示窄，1 表示横向很宽。",
    "round": "圆唇程度，0 表示不圆唇，1 表示明显圆唇。",
    "jaw": "下颌下落程度，用于表现大开口时的下巴运动。",
    "smile": "嘴角上扬程度，用于表现 i/e/y 等横向展开音。",
    "tension": "嘴唇紧张程度，用于表现齿音、擦音和闭唇音。"
  },
  "audioGuide": {
    "mode": "silence 表示静音，tone 表示纯音，noise 表示噪声，mixed 表示纯音加噪声。",
    "frequencyHz": "主音频率，数值越高听起来越尖。",
    "secondFrequencyHz": "辅助音频率，0 表示不启用辅助音。",
    "noise": "噪声比例，适合 f/s/sh/th 这类擦音。",
    "gain": "音量，建议保持在 0.03 到 0.14 之间，避免浏览器播放过响。",
    "syllable": "报告中显示的临时发声提示。"
  },
