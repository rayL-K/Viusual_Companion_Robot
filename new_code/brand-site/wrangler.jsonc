{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "veyralux-brand-site",
  "compatibility_date": "2026-07-13",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "none"
  },
  "routes": [
    {
      "pattern": "veyralux.org",
      "custom_domain": true
    }
  ]
}
