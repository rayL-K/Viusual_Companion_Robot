# 安装时复制到 /etc/veyrasoul/veyrasoul.env，权限设为 600；不要提交真实密钥。
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=256

VEYRASOUL_ASR_MODEL_DIR=/opt/veyrasoul/models/asr/zipformer-zh-en-int8
VEYRASOUL_ASR_THREADS=4
VEYRASOUL_ASR_RULE2_SILENCE=0.55
VEYRASOUL_TTS_MODEL_DIR=/opt/veyrasoul/models/tts/kokoro-zh-en
VEYRASOUL_TTS_THREADS=4
VEYRASOUL_MEMORY_PATH=/home/wenkang/.local/share/veyrasoul/veyrasoul.db
VEYRASOUL_VLM_URL=http://127.0.0.1:8767
VEYRASOUL_VISION_REFRESH_SECONDS=5
VEYRASOUL_WEB_DIST=/home/wenkang/embedded_competition/new_code/web/dist
VEYRASOUL_HOST=127.0.0.1
VEYRASOUL_PORT=8875
